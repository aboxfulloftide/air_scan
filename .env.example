# WiFi Scanner — Database Configuration
# Copy this file to .env and fill in your values
# Never commit .env to git

# MySQL server hostname or IP
DB_HOST=192.168.1.42

# Database credentials
DB_USER=networkscan
DB_PASS=changeme

# Database name
DB_NAME=wireless

# SSL mode — set to "enabled" if your MySQL server uses a valid certificate
DB_SSL=disabled
