[Unit]
Description=Air Scan API
After=network.target mysql.service
Wants=network.target

[Service]
Type=simple
User=matheau
WorkingDirectory=/home/matheau/code/air_scan
ExecStart=/home/matheau/miniforge3/bin/python3 -m uvicorn api.main:app --host 0.0.0.0 --port 8002 --timeout-keep-alive 2
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
